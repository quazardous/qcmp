{
  "name": "@quazardous/qcmp",
  "version": "0.2.0",
  "description": "qcmp (Quick Components) — inventory + version extractors + bumpers driven by qcmp.yaml at the project root.",
  "license": "MIT",
  "author": "David Berlioz",
  "repository": {
    "type": "git",
    "url": "https://github.com/quazardous/qcmp.git"
  },
  "homepage": "https://github.com/quazardous/qcmp#readme",
  "bugs": {
    "url": "https://github.com/quazardous/qcmp/issues"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "bin",
    "README.md",
    "CHANGELOG.md"
  ],
  "bin": {
    "qcmp": "./bin/qcmp"
  },
  "scripts": {
    "start": "tsx src/cli.ts",
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepare": "npm run build",
    "prepublishOnly": "npm run test"
  },
  "dependencies": {
    "commander": "^14.0.3",
    "yaml": "^2.6.0"
  },
  "devDependencies": {
    "@types/node": "^22.7.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^4.1.7"
  },
  "engines": {
    "node": ">=20"
  }
}
