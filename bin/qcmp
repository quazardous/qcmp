#!/usr/bin/env bash
# qcmp (Quick Components) — inventory + version extractors + bumpers
# driven by qcmp.yaml at the project root. See README.md.
#
# Runs the built CLI (dist/cli.js) under plain node — no tsx at runtime.
# `npm run build` (or `npm install`, via the prepare script) produces dist/.
set -eo pipefail

SELF="$0"
while [[ -L "$SELF" ]]; do
    target="$(readlink "$SELF")"
    if [[ "$target" = /* ]]; then SELF="$target"; else SELF="$(dirname "$SELF")/$target"; fi
done
BIN_DIR="$(cd "$(dirname "$SELF")" && pwd)"
PKG_ROOT="$(cd "$BIN_DIR/.." && pwd)"

ENTRY="$PKG_ROOT/dist/cli.js"
if [[ ! -f "$ENTRY" ]]; then
    echo "qcmp: $ENTRY missing — run 'npm run build' in $PKG_ROOT first" >&2
    exit 1
fi

# Preserve the invoker's cwd so the parser's walk-up sees the user's
# project tree, not the install dir. cli.ts reads QCMP_CWD when set. No
# cd needed: node resolves node_modules relative to the script, not cwd.
exec env QCMP_CWD="$PWD" node "$ENTRY" "$@"
